---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
import GlobalPlayer from '../components/GlobalPlayer';
import { Toaster } from 'sonner';
import { Mic, FileText, Headphones, Music, Mic2, Rss, Globe, Moon, Sun, LayoutGrid } from 'lucide-react';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
    <script is:inline>
      const theme = (() => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
          return 'dark';
        }
        return 'light';
      })();
      if (theme === 'light') {
        document.documentElement.classList.remove('dark');
        document.documentElement.classList.add('light');
      } else {
        document.documentElement.classList.add('dark');
        document.documentElement.classList.remove('light');
      }
    </script>
    <ClientRouter />
  </head>
  <body>
    <div class="app-container">
      <!-- 1. Slim Sidebar -->
      <aside class="slim-sidebar">
        <div class="vertical-text"><span>主播</span><b>林深 / 若水</b></div>
        <div class="sidebar-footer flex flex-col gap-6 items-center pb-10">
          <a href="https://github.com/wang-h/natural-ai-podcast" target="_blank" class="text-muted-foreground hover:text-foreground transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-github" aria-hidden="true"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"></path><path d="M9 18c-4.51 2-5-2-7-2"></path></svg>
          </a>
          <button id="theme-toggle" class="text-muted-foreground hover:text-foreground transition-colors cursor-pointer p-0 border-none bg-none">
            <Moon size={20} className="dark:hidden" />
            <Sun size={20} className="hidden dark:block" />
          </button>
        </div>
      </aside>

      <!-- 2. Info Sidebar -->
      <section class="info-sidebar">
        <div class="podcast-cover-box">
          <div class="podcast-cover-content">
            <div class="podcast-cover-haze">
              <Mic className="text-white w-14 h-14 drop-shadow-2xl" strokeWidth={1.5} />
              <div class="brand-text">
                <span class="brand-main">Natural AI</span>
                <span class="brand-sub">PODcast</span>
              </div>
            </div>
          </div>
        </div>
        
        <div class="podcast-info">
          <h1 class="flex flex-col leading-none tracking-tighter">
            <span class="text-2xl font-[1000] bg-gradient-to-br from-emerald-400 to-sky-500 bg-clip-text text-transparent">Natural AI</span>
            <span class="text-[0.65rem] font-black uppercase tracking-[0.4em] opacity-30 mt-1">PODcast</span>
          </h1>
        </div>
        
        <div class="info-sections space-y-12">
          <section>
            <div class="section-label">
              <div class="square-icon"></div>
              <span>关于</span>
            </div>
            <div class="description-box text-sm leading-relaxed opacity-80">
              <b>林深 & 若水</b> 的深夜对谈。<br/>
              在这里，AI 不再是冰冷的算法，而是带有<b>呼吸、犹豫和情感</b>的灵魂。<br/>
              我们追求极致的<b>自然感</b>，复刻最真实的临场气场，让每一次收听都宛如挚友对坐。
            </div>
          </section>

          <section>
            <div class="section-label">
              <div class="square-icon bg-gradient-to-r from-blue-500 to-emerald-500"></div>
              <span>功能</span>
            </div>
            <nav class="flex flex-col gap-1">
              <a href="/" class="nav-item group">
                <LayoutGrid size={18} className="text-indigo-500 group-hover:scale-110 transition-transform" />
                <span>返回首页</span>
              </a>
              <a href="/script/" class="nav-item group api-only">
                <FileText size={18} className="text-sky-500 group-hover:scale-110 transition-transform" />
                <span>Text → Script</span>
              </a>
              <a href="/render/" class="nav-item group api-only">
                <Headphones size={18} className="text-emerald-500 group-hover:scale-110 transition-transform" />
                <span>Script → Audio</span>
              </a>
            </nav>
          </section>

          <section>
            <div class="section-label">
              <div class="square-icon bg-gradient-to-r from-emerald-500 to-blue-500"></div>
              <span>订阅</span>
            </div>
            <nav class="flex flex-col gap-1">
              <a href="#" class="nav-item group">
                <Music size={18} className="text-red-400" />
                <span>网易云音乐</span>
              </a>
              <a href="https://www.xiaoyuzhoufm.com/podcast/67b06023606e5c59409cd9ba" target="_blank" class="nav-item group">
                <Mic2 size={18} className="text-sky-400" />
                <span>小宇宙</span>
              </a>
              <a href="/rss.xml" class="nav-item group">
                <Rss size={18} className="text-orange-400" />
                <span>RSS Feed</span>
              </a>
              <a href="https://www.deepling.tech" target="_blank" class="nav-item group">
                <Globe size={18} className="text-indigo-400" />
                <span>深灵.Tech</span>
              </a>
            </nav>
          </section>
        </div>
      </section>

      <!-- 3. Main Content -->
      <main class="main-content">
        <slot />
        <footer class="py-20 text-center border-t">
          <p class="text-xs font-bold text-muted-foreground uppercase tracking-widest">
            natural-ai-podcast
          </p>
        </footer>
      </main>
    </div>

    <!-- Persistent React Player as an Island -->
    <GlobalPlayer client:load />
    <Toaster client:load richColors position="top-center" />
    
    <script>
      function init() {
        const handleToggleClick = () => {
          const element = document.documentElement;
          element.classList.toggle('dark');
          element.classList.toggle('light');
          const isDark = element.classList.contains('dark');
          localStorage.setItem('theme', isDark ? 'dark' : 'light');
        }

        const themeToggle = document.getElementById('theme-toggle');
        if (themeToggle) {
          themeToggle.addEventListener('click', handleToggleClick);
        }

        // Hide API-only nav items on static deployments (no backend)
        fetch('/api/runs', { method: 'HEAD' }).catch(() => {
          document.querySelectorAll('.api-only').forEach(el => {
            (el as HTMLElement).style.display = 'none';
          });
        });
      }

      document.addEventListener('astro:page-load', init);
      init();
    </script>
  </body>
</html>
