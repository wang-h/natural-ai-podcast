---
import Layout from '../layouts/Layout.astro';
import EpisodeList from '../components/EpisodeList';
---

<Layout title="natural-ai-podcast">
  <div class="list-header"><h2>最近更新</h2></div>
  <div id="static-notice" style="display:none;margin-bottom:2rem;padding:0.75rem 1rem;border:1px solid var(--border);border-radius:0.5rem;font-size:0.8rem;color:var(--muted-foreground);background:color-mix(in srgb, var(--muted) 5%, transparent);">
    这是静态演示版本，仅展示已生成的播客内容。如需在线生成脚本和音频，请克隆项目并在本地运行。
  </div>
  <EpisodeList client:load />
  <script is:inline>
    // Show notice only on static deployment (no backend API)
    fetch('/api/runs', { method: 'HEAD' }).catch(() => {
      const n = document.getElementById('static-notice');
      if (n) n.style.display = 'block';
    });
  </script>
</Layout>
