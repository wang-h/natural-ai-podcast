# ---- LLM Configuration ----
# API Key (used for both OpenAI-compatible and Anthropic-compatible endpoints)
OPENAI_API_KEY=
# or ANTHROPIC_API_KEY=

# LLM Base URL (optional, defaults to MiniMax)
OPENAI_BASE_URL=https://api.minimaxi.com/v1
ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic

# LLM Model (optional, defaults to MiniMax-Text-01)
OPENAI_MODEL=MiniMax-Text-01
ANTHROPIC_MODEL=MiniMax-Text-01

# ---- TTS Configuration ----
# MiniMax TTS API Key (falls back to OPENAI_API_KEY if not set)
MINIMAX_TTS_API_KEY=
MINIMAX_TTS_BASE_URL=https://api.minimaxi.com
MINIMAX_TTS_MODEL=speech-2.8-hd
